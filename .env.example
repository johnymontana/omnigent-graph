# ─────────────────────────────────────────────────────────────────────────────
# omnigent-neo4j-memory — environment
# Copy to `.env` and fill in. NEVER commit a real nams_ key.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend selection ────────────────────────────────────────────────────────
# NAMS (hosted) is used when MEMORY_API_KEY is a REAL key; otherwise the local Neo4j settings below
# are used. This secret lives ONLY on the host that runs the sidecar — never in an agent YAML or a
# sandbox. Left commented so a copied .env defaults to the local path instead of a confusing 401.
#
# NAMS path — uncomment and set your real key (recommended; zero infra):
# MEMORY_API_KEY=nams_your_real_key_here
# NAMS base URL (default https://memory.neo4jlabs.com/v1; REST mode when the URL contains /v<N>):
# MEMORY_ENDPOINT=https://memory.neo4jlabs.com/v1
#
# NOTE: these values are parsed by make/shell — keep them unquoted and free of spaces, '#', and '$'.

# ── Local Neo4j fallback (used only when MEMORY_API_KEY is unset) ─────────────
# These match the docker-compose `neo4j` service in the `local` profile.
NAM_NEO4J__URI=bolt://localhost:7687
NAM_NEO4J__USERNAME=neo4j
NAM_NEO4J__PASSWORD=please-change-me
# Local path runs embeddings on your machine. Install the backend once — the base package ships
# none and would otherwise fall back to the OpenAI embedder (needs a key):
#   pip install '.[local]'      (or: make install-local)
# These select the local, no-API-key sentence-transformers embedder:
NAM_EMBEDDING__PROVIDER=sentence_transformers
NAM_EMBEDDING__MODEL=BAAI/bge-small-en-v1.5

# ── Sidecar (host-level shared MCP server — see ADR-0001) ─────────────────────
OMNIGENT_MEMORY_HOST=0.0.0.0
OMNIGENT_MEMORY_PORT=8000
OMNIGENT_MEMORY_TRANSPORT=sse
# MCP tool profile: `extended` (full set — needed for graph_query + memory_add_fact) or `core`.
OMNIGENT_MEMORY_PROFILE=extended

# ── Demo: shared session id for the Polly-memory run (see scripts + agents) ───
# Minted per task; both coder and reviewer use this exact value so they share
# one memory scope. The demo exports it before `omnigent run`.
SESSION_ID=task-local-001
